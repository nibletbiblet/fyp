<%- include("partials-header") %>

<div class="container py-5">
  <div class="row g-4">
    <div class="col-lg-6">
      <div class="card shadow-sm h-100">
        <div class="card-body p-4">
          <h2 class="fw-bold">Customer Payment Page</h2>
          <p class="text-muted">The customer would scan this QR and pay using a crypto wallet or exchange wallet.</p>

          <div class="qr-box my-4">
            <img class="qr-image" src="<%= qrCodeDataUrl %>" alt="Payment QR code">
            <p class="small text-muted mt-2 mb-0">Mock QR: <%= payment.walletAddress %></p>
          </div>

          <div class="payment-details">
            <p><strong>Merchant:</strong> <%= payment.merchantName %></p>
            <p><strong>Customer:</strong> <%= payment.customerName %></p>
            <p><strong>Reference:</strong> <%= payment.reference %></p>
            <p><strong>Pay:</strong> <%= payment.cryptoAmount %> <%= payment.cryptoCurrency %></p>
            <p><strong>Network:</strong> <%= payment.network %></p>
            <p><strong>Wallet Address:</strong> <span class="text-break"><%= payment.walletAddress %></span></p>
            <p><strong>Expires:</strong> <%= payment.expiresAt || "Not set" %></p>
            <% if (payment.paymentStatus === "PENDING" && payment.expiresAtIso) { %>
              <p><strong>Time Remaining:</strong> <span id="expiryCountdown" data-expires-at="<%= payment.expiresAtIso %>">Calculating...</span></p>
            <% } %>
          </div>

          <% if (payment.paymentStatus === "PENDING") { %>
            <form method="POST" action="/simulate-payment/<%= payment.id %>">
              <button class="btn btn-success w-100">Simulate Customer Payment</button>
            </form>
          <% } else if (payment.paymentStatus === "EXPIRED") { %>
            <button class="btn btn-danger w-100" disabled>Payment Expired</button>
          <% } else { %>
            <button class="btn btn-success w-100" disabled>Payment Confirmed</button>
          <% } %>
        </div>
      </div>
    </div>

    <div class="col-lg-6">
      <div class="card shadow-sm h-100">
        <div class="card-body p-4">
          <h2 class="fw-bold">Merchant Settlement View</h2>
          <p class="text-muted">This shows how Uniweb tracks payment and mock SGD settlement.</p>

          <div class="timeline">
            <div class="timeline-item active">
              <h5>1. Payment Request Created</h5>
              <p>Uniweb generated a payment record and mock BVNK wallet details.</p>
            </div>

            <div class="timeline-item <%= payment.paymentStatus === 'PAID' ? 'active' : '' %>">
              <h5>2. Blockchain Payment Confirmed</h5>
              <p>Status: <strong><%= payment.paymentStatus %></strong><% if (payment.paidAt) { %> at <%= payment.paidAt %><% } %></p>
            </div>

            <div class="timeline-item <%= payment.settlementStatus === 'SETTLED_TO_MERCHANT_SGD' ? 'active' : '' %>">
              <h5>3. T+1 SGD Settlement</h5>
              <p>Status: <strong><%= payment.settlementStatus %></strong><% if (payment.settledAt) { %> at <%= payment.settledAt %><% } %></p>
            </div>
          </div>

          <hr>

          <p><strong>Original Amount:</strong> SGD <%= payment.fiatAmount.toFixed(2) %></p>
          <p><strong>Mock Rate:</strong> 1 <%= payment.cryptoCurrency %> = SGD <%= payment.exchangeRate %></p>
          <p><strong>Received Crypto:</strong> <%= payment.cryptoAmount %> <%= payment.cryptoCurrency %></p>
          <p><strong>Processor Fee:</strong> SGD <%= payment.processorFee.toFixed(2) %></p>
          <p><strong>Network Fee:</strong> SGD <%= payment.networkFee.toFixed(2) %></p>
          <p><strong>Net Settlement:</strong> SGD <%= payment.netSettlementAmount.toFixed(2) %></p>

          <% if (blockchainTransactions.length > 0) { %>
            <hr>
            <h5 class="fw-bold">Blockchain Transaction</h5>
            <% blockchainTransactions.forEach(tx => { %>
              <div class="small mb-3">
                <p class="mb-1"><strong>Tx Hash:</strong> <span class="text-break"><%= tx.txHash %></span></p>
                <p class="mb-1"><strong>Network:</strong> <%= tx.network %></p>
                <p class="mb-1"><strong>From:</strong> <span class="text-break"><%= tx.fromWallet %></span></p>
                <p class="mb-1"><strong>To:</strong> <span class="text-break"><%= tx.toWallet %></span></p>
                <p class="mb-1"><strong>Received:</strong> <%= tx.receivedAmount %> <%= tx.currency %></p>
                <p class="mb-1"><strong>Confirmations:</strong> <%= tx.confirmations %></p>
                <p class="mb-0"><strong>Confirmed:</strong> <%= tx.confirmedAt %></p>
              </div>
            <% }) %>
          <% } %>

          <% if (payment.statusReason) { %>
            <div class="alert alert-danger"><%= payment.statusReason %></div>
          <% } %>

          <% if (payment.settlementStatus === "SCHEDULED_T_PLUS_1") { %>
            <div class="alert alert-info">
              Settlement has been automatically added to the merchant's T+1 batch.
            </div>
          <% } else if (payment.settlementStatus === "SETTLED_TO_MERCHANT_SGD") { %>
            <div class="alert alert-success">
              Merchant settlement completed: SGD <%= payment.fiatAmount.toFixed(2) %>
            </div>
          <% } else { %>
            <div class="alert alert-warning">
              Waiting for customer payment before settlement can begin.
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const expiryCountdown = document.getElementById("expiryCountdown");

  if (expiryCountdown) {
    const expiresAt = new Date(expiryCountdown.dataset.expiresAt).getTime();

    function updateExpiryCountdown() {
      const remaining = expiresAt - Date.now();

      if (remaining <= 0) {
        expiryCountdown.textContent = "Expired";
        return;
      }

      const totalSeconds = Math.floor(remaining / 1000);
      const minutes = Math.floor(totalSeconds / 60);
      const seconds = totalSeconds % 60;
      expiryCountdown.textContent = `${minutes}m ${seconds.toString().padStart(2, "0")}s`;
    }

    updateExpiryCountdown();
    setInterval(updateExpiryCountdown, 1000);
  }
</script>

<%- include("partials-footer") %>
