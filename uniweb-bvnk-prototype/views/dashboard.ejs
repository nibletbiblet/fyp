<%- include("partials-header") %>

<div class="container py-5">
  <div class="hero-card p-5 mb-4">
    <h1 class="fw-bold">Crypto-to-SGD Payment Settlement Dashboard</h1>
    <p class="lead mb-0">
      Uniweb helps merchants accept stablecoin payments while a mock BVNK layer handles blockchain confirmation, conversion, and SGD settlement.
    </p>
  </div>

  <div class="row g-4 mb-4">
    <div class="col-md">
      <div class="card stat-card">
        <div class="card-body">
          <p class="text-muted mb-1">Total Payments</p>
          <h2><%= totalPayments %></h2>
        </div>
      </div>
    </div>
    <div class="col-md">
      <div class="card stat-card">
        <div class="card-body">
          <p class="text-muted mb-1">Pending</p>
          <h2><%= pendingPayments %></h2>
        </div>
      </div>
    </div>
    <div class="col-md">
      <div class="card stat-card">
        <div class="card-body">
          <p class="text-muted mb-1">Paid</p>
          <h2><%= paidPayments %></h2>
        </div>
      </div>
    </div>
    <div class="col-md">
      <div class="card stat-card">
        <div class="card-body">
          <p class="text-muted mb-1">Expired</p>
          <h2><%= expiredPayments %></h2>
        </div>
      </div>
    </div>
    <div class="col-md">
      <div class="card stat-card">
        <div class="card-body">
          <p class="text-muted mb-1">Scheduled</p>
          <h2><%= scheduledSettlements %></h2>
        </div>
      </div>
    </div>
    <div class="col-md">
      <div class="card stat-card">
        <div class="card-body">
          <p class="text-muted mb-1">Settled</p>
          <h2><%= settledPayments %></h2>
        </div>
      </div>
    </div>
  </div>

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Recent Payments</h3>
    <a href="/create-payment" class="btn btn-primary">Create New Payment</a>
  </div>

  <div class="card">
    <div class="card-body table-responsive">
      <table class="table align-middle">
        <thead>
          <tr>
            <th>Reference</th>
            <th>Merchant</th>
            <th>Amount</th>
            <th>Crypto</th>
            <th>Fees</th>
            <th>Net</th>
            <th>Payment</th>
            <th>Settlement</th>
            <th>Expires</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% payments.forEach(payment => { %>
            <tr>
              <td><%= payment.reference %></td>
              <td><%= payment.merchantName %></td>
              <td><%= payment.fiatCurrency %> <%= payment.fiatAmount.toFixed(2) %></td>
              <td><%= payment.cryptoAmount %> <%= payment.cryptoCurrency %></td>
              <td>SGD <%= (payment.processorFee + payment.networkFee).toFixed(2) %></td>
              <td>SGD <%= payment.netSettlementAmount.toFixed(2) %></td>
              <td><span class="badge bg-<%= payment.paymentStatus === 'PAID' ? 'success' : payment.paymentStatus === 'EXPIRED' || payment.paymentStatus === 'FAILED' ? 'danger' : 'warning' %>"><%= payment.paymentStatus %></span></td>
              <td><span class="badge bg-<%= payment.settlementStatus === 'SETTLED_TO_MERCHANT_SGD' ? 'success' : 'secondary' %>"><%= payment.settlementStatus %></span></td>
              <td><%= payment.expiresAt || "-" %></td>
              <td><a class="btn btn-sm btn-outline-primary" href="/payment/<%= payment.id %>">View</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include("partials-footer") %>
