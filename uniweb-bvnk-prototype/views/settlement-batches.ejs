<%- include("partials-header") %>

<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Daily T+1 Settlement Batches</h2>
  </div>

  <div class="card">
    <div class="card-body table-responsive">
      <table class="table table-hover align-middle">
        <thead>
          <tr>
            <th>Batch</th>
            <th>Payments</th>
            <th>Gross</th>
            <th>Fees</th>
            <th>Net Settlement</th>
            <th>Status</th>
            <th>Payout</th>
            <th>Bank Account</th>
            <th>Settlement Date</th>
            <th>Settled</th>
          </tr>
        </thead>
        <tbody>
          <% batches.forEach(batch => { %>
            <tr>
              <td><%= batch.batchReference %></td>
              <td><%= batch.paymentCount %></td>
              <td>SGD <%= batch.grossAmount.toFixed(2) %></td>
              <td>SGD <%= batch.totalFees.toFixed(2) %></td>
              <td>SGD <%= batch.netAmount.toFixed(2) %></td>
              <td><span class="badge bg-<%= batch.status === 'SETTLED' ? 'success' : 'info' %>"><%= batch.status %></span></td>
              <td><span class="badge bg-secondary"><%= batch.payoutStatus %></span></td>
              <td><%= batch.bankName %> ****<%= batch.accountLast4 %></td>
              <td><%= batch.settlementDate || "-" %></td>
              <td><%= batch.settledAt || "-" %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include("partials-footer") %>
